# Member auth (NextAuth) — required for social login reviews
# Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google — https://console.cloud.google.com/apis/credentials
# Redirect URI (required): http://localhost:3000/api/auth/callback/google
# JavaScript origin (required): http://localhost:3000
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook — https://developers.facebook.com/apps/
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# X (Twitter) — https://developer.twitter.com/en/portal/dashboard
AUTH_TWITTER_ID=
AUTH_TWITTER_SECRET=

# Optional — exact address from Google Business Profile (free $200/mo Google credit)
# Enable "Places API (New)" in Google Cloud Console
GOOGLE_PLACES_API_KEY=

# Playwright headless scrape for GBP address (default: enabled). Set false to skip (~15s slower path).
PLAYWRIGHT_GBP_ENABLED=

# Site URL for claim/manage emails
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email — required for OTP to reach users in production
# Get a free key at https://resend.com
# With onboarding@resend.dev you can only send to your Resend account email until you verify a domain.
RESEND_API_KEY=
LISTING_EMAIL_FROM=Submit Your Store <onboarding@resend.dev>
